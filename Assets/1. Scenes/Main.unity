--- !u!114 &229942399
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 229942397}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC0AC\uB791\uD558\uB294 \uB098\uC758 \uC544\uC774\uB4E4\uC5D0\uAC8C.\n\n\uC774
    \uD3B8\uC9C0\uB97C \uC77D\uACE0 \uC788\uB2E4\uB294\uAC74,\n\uB0B4\uAC00 \uBB3C\uAC74\uB4E4\uC5D0
    \uC228\uACA8\uB193\uC740 \uCABD\uC9C0\uB4E4\uC744 \uC804\uBD80 \uCC3E\uC544\uB0C8\uB2E4\uB294
    \uAC70\uACA0\uC9C0.\n\uADF8\uB798, \uC6B0\uB9AC\uC758 \uCD94\uC5B5\uC774 \uB2F4\uAE34
    \uBB3C\uAC74\uB4E4 \uB9D0\uC774\uC57C.\n\n\uAD1C\uD788 \uD798\uB4E0 \uC77C\uB9CC
    \uC2DC\uD0A8\uAC74 \uC544\uB2D0\uC9C0 \uB9C8\uC74C\uC774 \uC4F0\uC774\uB124.\n\uB458\uC774\uC11C
    \uCABD\uC9C0 \uCC3E\uB294\uB2E4\uACE0 \uC2F8\uC6B0\uC9C0\uB294 \uC54A\uC558\uC9C0?\n\uADF8\uB798\uB3C4
    \uB108\uD76C \uB355\uBD84\uC5D0, \uC774 \uD3B8\uC9C0\uB97C \uC804\uD558\uAC8C
    \uB420 \uC218 \uC788\uC73C\uB2C8\uAE4C.\n\n\uC694\uC998\uC740 \uC5B4\uB5BB\uAC8C
    \uC9C0\uB0B4\uACE0 \uC788\uC5B4?\n\n\uB098 \uB54C\uBB38\uC5D0 \uACC4\uC18D \uC2AC\uD37C\uD558\uACE0
    \uC788\uB294\uAC8C \uC544\uB2D0\uC9C0. \uADF8\uAC8C \uC81C\uC77C \uAC71\uC815\uC774\uC57C.\n\n\uADF8\uB798\uB3C4
    \uC2AC\uD37C\uD558\uC9C0 \uB9D0\uB77C\uB294 \uB9D0\uC740 \uD558\uC9C0 \uC54A\uC744\uAC8C.\n\uC6B8\uACE0
    \uC2F6\uC744 \uB550 \uB9C8\uC74C\uAECF \uC6B8\uC5B4\uB3C4 \uB418\uB294\uAC78.\n\uB2E4\uB9CC
    \uADF8 \uC2AC\uD514\uC774 \uB108\uD76C\uC758 \uC0B6\uC744 \uC804\uBD80 \uAC00\uC838\uAC00\uC9C0\uB294
    \uC54A\uC558\uC73C\uBA74 \uC88B\uACA0\uAD6C\uB098.\n\n\uBC25, \uC798 \uCC59\uACA8
    \uBA39\uACE0. \uB108\uBB34 \uB2A6\uAC8C\uAE4C\uC9C0 \uBB34\uB9AC\uD558\uC9C0
    \uB9D0\uACE0.\n\uAC00\uB054\uC740 \uCC3D\uBB38\uC744 \uC5F4\uACE0 \uADF8\uC800
    \uB05D\uC5C6\uB294 \uD558\uB298\uC744 \uBC14\uB77C\uBD10\uBD10.\n\uBCC4 \uAC83
    \uC544\uB2CC \uC77C\uB4E4\uC774\uC9C0\uB9CC, \n\uADF8\uC800 \uB108\uD76C\uAC00
    \uD3C9\uBC94\uD55C \uD558\uB8E8\uD558\uB8E8\uB97C \uC0B4\uC544\uAC14\uC73C\uBA74
    \uD558\uB294 \uC791\uC740 \uBC14\uB7A8\uC774\uC57C.\n\n\uC788\uC9C0, \uBE44\uB85D
    \uC55E\uC73C\uB85C \uB9CC\uB0A0 \uC218\uB294 \uC5C6\uACA0\uC9C0\uB9CC, \n\uC774\uACF3\uC5D0\uC11C
    \uB108\uD76C\uB4E4\uC744 \uC5B8\uC81C\uAE4C\uC9C0\uACE0 \uC9C0\uCF1C\uBCF4\uBA74\uC11C
    \uC751\uC6D0\uD574\uC904\uAC8C.\n\uADF8\uB7EC\uB2C8 \uAE30\uC5B5\uD574\uC904\uB798?
    \uC6B0\uB9AC\uC758 \uCD94\uC5B5\uB4E4\uC744 \uC78A\uC9C0 \uB9D0\uC544\uC918.\n\n\uC544\uC544,
    \uC2DC\uAC04\uC774 \uBD80\uC871\uD55C\uAC78.\n\uC815\uB9D0 \uB9C8\uC9C0\uB9C9\uC73C\uB85C,
    \uB531 \uD55C\uB9C8\uB514\uB9CC \uB108\uD76C\uC5D0\uAC8C \uC804\uD560 \uC218
    \uC788\uB2E4\uBA74...\n\n\uC0AC\uB791\uD574.\n\n\uC870\uAE08 \uBED4\uD588\uB2C8?\n\uC544\uBE60\uAC00.\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d74c2720160c7424194c3cbf79afd2cb, type: 2}
  m_sharedMaterial: {fileID: 4507231753285863310, guid: d74c2720160c7424194c3cbf79afd2cb, type: 2}
